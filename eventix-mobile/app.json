{
  "expo": {
    "name": "Eventix",
    "slug": "eventix-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f0f1a"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0f0f1a"
      },
      "package": "com.eventix.mobile"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.eventix.mobile"
    },
    "plugins": [
      "expo-secure-store",
      "expo-image-picker"
    ]
  }
}
